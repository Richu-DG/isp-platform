{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "./dist",
    "baseUrl": "./",
    "strictPropertyInitialization": false,
    "skipLibCheck": true,
    "noImplicitAny": false,
    "strict": false,
    "declaration": false,
    "paths": {
      "@isp/database": ["../../packages/database/dist/index"],
      "@isp/shared": ["../../packages/shared/dist/index"]
    }
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist", "test"]
}
