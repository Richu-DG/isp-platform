# ─── Supabase ─────────────────────────────────────────────
DATABASE_URL="postgresql://postgres.PROJECT_REF:PASSWORD@aws-0-eu-central-1.pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_DATABASE_URL="postgresql://postgres.PROJECT_REF:PASSWORD@aws-0-eu-central-1.pooler.supabase.com:5432/postgres"
SUPABASE_URL="https://PROJECT_REF.supabase.co"
SUPABASE_ANON_KEY="your-anon-key"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# ─── Redis (Railway) ──────────────────────────────────────
REDIS_URL="redis://default:PASSWORD@HOST:PORT"

# ─── JWT ──────────────────────────────────────────────────
JWT_SECRET="change-me-to-a-64-char-random-string"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_SECRET="change-me-to-another-64-char-random-string"
JWT_REFRESH_EXPIRES_IN="7d"

# ─── App ──────────────────────────────────────────────────
NODE_ENV="development"
PORT=3001
API_URL="http://localhost:3001"
WEB_URL="http://localhost:3000"
PORTAL_URL="http://localhost:3002"
CORS_ORIGINS="http://localhost:3000,http://localhost:3002"

# ─── M-Pesa Daraja API ────────────────────────────────────
MPESA_CONSUMER_KEY="your-consumer-key"
MPESA_CONSUMER_SECRET="your-consumer-secret"
MPESA_ENVIRONMENT="sandbox"          # sandbox | production
MPESA_SHORTCODE="174379"
MPESA_PASSKEY="bfb279f9aa9bdbcf158e97dd71a467cd2e0c893059b10f78e6b72ada1ed2c919"
MPESA_STK_CALLBACK_URL="https://your-api.railway.app/api/payments/mpesa/stk-callback"
MPESA_C2B_VALIDATION_URL="https://your-api.railway.app/api/payments/mpesa/c2b-validation"
MPESA_C2B_CONFIRMATION_URL="https://your-api.railway.app/api/payments/mpesa/c2b-confirmation"

# ─── SMS (Africa's Talking) ───────────────────────────────
AT_USERNAME="sandbox"
AT_API_KEY="your-at-api-key"
AT_SMS_SENDER_ID=""

# ─── WhatsApp (WaBusiness / Twilio) ───────────────────────
WHATSAPP_PROVIDER="twilio"            # twilio | 360dialog
TWILIO_ACCOUNT_SID="ACxxxxxxxx"
TWILIO_AUTH_TOKEN="your-token"
TWILIO_WHATSAPP_FROM="whatsapp:+14155238886"

# ─── Email (Resend) ───────────────────────────────────────
RESEND_API_KEY="re_xxxx"
EMAIL_FROM="noreply@yourdomain.co.ke"

# ─── FreeRADIUS ───────────────────────────────────────────
RADIUS_HOST="localhost"
RADIUS_AUTH_PORT=1812
RADIUS_ACCT_PORT=1813
RADIUS_SECRET="radius-shared-secret"

# ─── Encryption ───────────────────────────────────────────
ENCRYPTION_KEY="32-char-hex-key-for-aes-256-gcm"

# ─── Rate Limiting ────────────────────────────────────────
THROTTLE_TTL=60
THROTTLE_LIMIT=100
