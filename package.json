{
  "name": "isp-platform",
  "version": "1.0.0",
  "private": true,
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "db:generate": "pnpm --filter @isp/database generate",
    "db:push": "pnpm --filter @isp/database db:push",
    "db:migrate": "pnpm --filter @isp/database migrate:deploy",
    "db:seed": "pnpm --filter @isp/database seed",
    "db:studio": "pnpm --filter @isp/database studio"
  },
  "devDependencies": {
    "turbo": "^2.0.0",
    "typescript": "^5.4.5",
    "@types/node": "^20.12.0",
    "prettier": "^3.2.5",
    "eslint": "^9.0.0"
  },
  "packageManager": "pnpm@9.4.0"
}
