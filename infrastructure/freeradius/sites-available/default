server default {
    listen {
        type = auth
        ipaddr = *
        port = 1812
        limit {
            max_connections = 16
            lifetime = 0
            idle_timeout = 30
        }
    }

    listen {
        type = acct
        ipaddr = *
        port = 1813
        limit {
            max_connections = 16
            lifetime = 0
            idle_timeout = 30
        }
    }

    authorize {
        filter_username
        preprocess
        suffix
        sql
        pap
    }

    authenticate {
        Auth-Type PAP {
            pap
        }
    }

    # Accounting — this is the primary function for multi-tenant ISP
    # MikroTik sends Start/Update/Stop records here for all PPPoE sessions
    preacct {
        preprocess
        acct_unique
        suffix
        files
    }

    accounting {
        sql         # Write all accounting records to Supabase radacct table
        unix
    }

    session {
        sql
    }

    post-auth {
        sql
        Post-Auth-Type REJECT {
            sql
        }
    }
}
